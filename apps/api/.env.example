# --- Base de datos ---
DATABASE_URL="file:./prisma/dev.db"

# --- API ---
PORT=4000
WEB_ORIGIN="http://localhost:3000"

# --- Auth ---
JWT_SECRET="cambiar-este-secreto-en-produccion"
JWT_EXPIRES_IN="1d"

# --- Negocio ---
# Precio por sesion en pesos argentinos
DEFAULT_SESSION_PRICE=5000
# Porcentaje de descuento del abono mensual
DEFAULT_MONTHLY_DISCOUNT=20
# Maximo de intentos fallidos de login antes de bloquear la cuenta
MAX_LOGIN_ATTEMPTS=3
